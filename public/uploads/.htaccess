# Block all script execution inside /uploads/ — defense in depth.
# Even if an attacker manages to upload a PHP file disguised as an image,
# Apache will refuse to hand it to the PHP interpreter.

<FilesMatch "\.(php|phtml|phar|phps|pl|py|jsp|asp|aspx|sh|cgi)$">
    Require all denied
</FilesMatch>

# Turn off any interpreters Apache might have enabled
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
AddType text/plain .php .phtml .phps .phar
RemoveHandler .php .phtml .phps .phar
Options -ExecCGI
